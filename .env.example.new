# ==============================================================================
# Nexus Personal AI System - Environment Configuration Template
# ==============================================================================
# 🚀 Quick Setup:
#   1. Copy this file: cp .env.example .env
#   2. Generate secrets: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   3. Fill in your OpenRouter API key: https://openrouter.ai/keys
#   4. Start services: docker-compose up -d
#
# ⚠️ NEVER commit .env to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE (PostgreSQL 16 + pgvector)
# ------------------------------------------------------------------------------
# These defaults work with docker-compose.yml out of the box

NEXUS_DB_HOST=localhost
NEXUS_DB_PORT=5432
NEXUS_DB_NAME=nexus_db
NEXUS_DB_USER=nexus_user
NEXUS_DB_PASSWORD=changeme_strong_password  # ⚠️ Change for production!

# ------------------------------------------------------------------------------
# REDIS (Task Queue & Caching)
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=                             # Leave empty for local dev

# ------------------------------------------------------------------------------
# MINIO (S3-Compatible Object Storage)
# ------------------------------------------------------------------------------
# Stores receipts, attachments, and backups

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin                 # ⚠️ Change for production!
MINIO_SECRET_KEY=minioadmin                 # ⚠️ Change for production!
MINIO_BUCKET=nexus-data
MINIO_SECURE=false                          # Set true when using HTTPS

# ------------------------------------------------------------------------------
# SECURITY & AUTHENTICATION
# ------------------------------------------------------------------------------
# 🔐 Generate secure keys:
#   Secret Key:     python -c "import secrets; print(secrets.token_urlsafe(32))"
#   Encryption Key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

NEXUS_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32          # ⚠️ CRITICAL - MUST CHANGE!
NEXUS_ENCRYPTION_KEY=changeme_generate_with_openssl_rand_base64_32   # ⚠️ CRITICAL - MUST CHANGE!

# JWT token expiration settings
NEXUS_ACCESS_TOKEN_EXPIRE_MINUTES=60        # Access token lifetime (60 min default)
NEXUS_REFRESH_TOKEN_EXPIRE_DAYS=7           # Refresh token lifetime (7 days)

# ------------------------------------------------------------------------------
# AI/LLM CONFIGURATION
# ------------------------------------------------------------------------------
# 🤖 OpenRouter: https://openrouter.ai
# Supports 200+ models from OpenAI, Anthropic, Google, Meta, Mistral, etc.

OPENROUTER_API_KEY=                          # Get yours at https://openrouter.ai/keys

# Model selection (can be changed per-request via API)
LLM_DEFAULT_MODEL=anthropic/claude-3-5-sonnet    # Primary model
LLM_FALLBACK_MODEL=ollama/mistral:7b-instruct    # Local fallback (requires Ollama)
LLM_MAX_MONTHLY_COST=50.0                        # Budget cap (in USD)

# Optional: Self-hosted Ollama for privacy-first local inference
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:latest

# ------------------------------------------------------------------------------
# NOTIFICATIONS (Optional)
# ------------------------------------------------------------------------------
# 📱 Telegram Bot (for alerts and remote task creation)
TELEGRAM_BOT_TOKEN=                          # Get from @BotFather
TELEGRAM_CHAT_ID=                            # Your Telegram user ID

# 📧 Email (SMTP for alerts and receipts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                                   # Your Gmail address
SMTP_PASSWORD=                               # App password (not your Gmail password!)
SMTP_FROM=                                   # From address (usually same as SMTP_USER)

# 📲 Twilio (SMS for critical alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ------------------------------------------------------------------------------
# APPLICATION SETTINGS
# ------------------------------------------------------------------------------
NEXUS_ENV=development                        # development | production
NEXUS_DEBUG=true                             # Enable debug mode (dev only!)
NEXUS_LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR | CRITICAL

# API server settings
NEXUS_API_HOST=0.0.0.0                       # Bind to all interfaces
NEXUS_API_PORT=8000
NEXUS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173  # Web UI origins

# ------------------------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------------------------
# Enable/disable features during development

NEXUS_ENABLE_RECEIPT_OCR=true                # ML-powered receipt parsing
NEXUS_ENABLE_MFA=true                        # Multi-factor authentication (TOTP)
NEXUS_ENABLE_AUDIT_LOGS=true                 # Comprehensive audit trail
NEXUS_ENABLE_EMAIL_INTEGRATION=false         # Email-to-task (Phase 4)
NEXUS_ENABLE_SMS_INTEGRATION=false           # SMS-to-task (Phase 4)
NEXUS_ENABLE_VOICE_INTERFACE=false           # Voice assistant (Phase 5)

# ------------------------------------------------------------------------------
# MONITORING & OBSERVABILITY (Optional)
# ------------------------------------------------------------------------------
# Prometheus metrics are auto-exposed at /metrics endpoint
# Grafana dashboards available at http://localhost:3001 (admin/admin)

# OpenTelemetry (for advanced distributed tracing)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=nexus
# OTEL_TRACES_SAMPLER=always_on

# ------------------------------------------------------------------------------
# PERFORMANCE TUNING (Production)
# ------------------------------------------------------------------------------
# Database connection pooling
NEXUS_DB_POOL_SIZE=10                        # Max persistent connections
NEXUS_DB_MAX_OVERFLOW=20                     # Extra connections during spikes

# Celery worker configuration
CELERY_WORKER_CONCURRENCY=4                  # Worker processes (match CPU cores)
CELERY_TASK_SOFT_TIME_LIMIT=300              # Soft timeout (seconds)
CELERY_TASK_HARD_TIME_LIMIT=600              # Hard timeout (seconds)

# Rate limiting (requests per minute)
NEXUS_RATE_LIMIT_AUTH=5                      # Login attempts
NEXUS_RATE_LIMIT_API=60                      # General API calls

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
# 
# 📚 Resources:
#   - Full configuration guide: docs/OPERATIONS.md
#   - Security best practices: SECURITY.md  
#   - Troubleshooting: QUICKSTART.md
#   - Architecture overview: docs/architecture-diagram.html
#
# 🔒 Security Checklist:
#   ✅ Changed NEXUS_SECRET_KEY to a random 32-byte value
#   ✅ Changed NEXUS_ENCRYPTION_KEY to a Fernet key
#   ✅ Changed MinIO credentials (production only)
#   ✅ Set strong NEXUS_DB_PASSWORD
#   ✅ Added .env to .gitignore
#   ✅ Enabled MFA (NEXUS_ENABLE_MFA=true)
#
# ==============================================================================
