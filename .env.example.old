# Environment variables for Nexus

# Database
NEXUS_DB_HOST=localhost
NEXUS_DB_PORT=5432
NEXUS_DB_NAME=nexus_db
NEXUS_DB_USER=nexus_user
NEXUS_DB_PASSWORD=changeme_strong_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nexus-data
MINIO_SECURE=false

# Security
NEXUS_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
NEXUS_ENCRYPTION_KEY=changeme_generate_with_openssl_rand_base64_32
NEXUS_ACCESS_TOKEN_EXPIRE_MINUTES=60
NEXUS_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM APIs
OPENROUTER_API_KEY=
LLM_DEFAULT_MODEL=anthropic/claude-3-5-sonnet
LLM_FALLBACK_MODEL=ollama/mistral:7b-instruct
LLM_MAX_MONTHLY_COST=50.0

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Twilio (optional, for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Application
NEXUS_ENV=development
NEXUS_DEBUG=true
NEXUS_LOG_LEVEL=INFO
